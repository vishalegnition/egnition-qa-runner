# ─── Railway webhook ────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000

# ─── BrowserStack Automate (Playwright CDP) + Shopify login ─────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
# BrowserStack: use email/password login (cookies are IP-bound and won't work on BS)
SHOPIFY_ADMIN_EMAIL=
SHOPIFY_ADMIN_PASSWORD=
SHOPIFY_2FA_SECRET=
# Optional — only for local/same-IP runs. On BrowserStack use login instead.
# SHOPIFY_SESSION_COOKIES=
# login | cookies | auto (auto = login on BrowserStack when credentials set)
# SHOPIFY_AUTH_MODE=login
# CapSolver only (Cloudflare challenge API — not passed to browser)
# CAPSOLVER_API_KEY=
# CAPSOLVER_PROXY=

# ─── Test runner ────────────────────────────────────────────────────────────
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Set true to run only the first test case in a cycle (smoke test)
# SMOKE_TEST=true

# ─── Local web runner (Ivan/Anastasia — pre-configured, not edited by users) ──
RAILWAY_CONFIG_URL=https://qa-automation-production-9b20.up.railway.app/config
RAILWAY_CONFIG_SECRET=
CHROME_DEBUG_PORT=9222
LOCAL_PORT=3000

# ─── Railway: local runner config endpoint ──────────────────────────────────
# RAILWAY_CONFIG_SECRET=  (same value as in bundled local .env)
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp

# ─── Local dev (optional) ───────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://your-org.atlassian.net
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2
APP=
CYCLE_ID=
