SHOPIFY_2FA_SECRET=
ZEPHYR_BASE_URL=https://your-org.atlassian.net
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=   # optional override; auto-selects best Gemini vision model if unset
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Workflow inputs (local dev only — set via workflow_dispatch in CI)
APP=
CYCLE_ID=
