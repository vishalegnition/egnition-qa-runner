# ─── Railway webhook ────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000

# ─── Steel.dev cloud browser + Shopify login ────────────────────────────────
STEEL_API_KEY=
# Hobby plan: proxy and captcha require paid plan — leave false
STEEL_USE_PROXY=false
STEEL_SOLVE_CAPTCHA=false
# Max session ms (Hobby cap = 900000 / 15 min)
STEEL_SESSION_TIMEOUT_MS=900000
# Optional: skip login if cookies exported from dev store admin
SHOPIFY_SESSION_COOKIES=
SHOPIFY_ADMIN_EMAIL=
SHOPIFY_ADMIN_PASSWORD=
SHOPIFY_2FA_SECRET=

# ─── Test runner ────────────────────────────────────────────────────────────
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─── Local dev (optional) ───────────────────────────────────────────────────
