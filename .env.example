# ─── Railway Webhook Receiver ───────────────────────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000

# ─── GitHub Actions / Local Runner ──────────────────────────────────────────
SHOPIFY_ADMIN_EMAIL=
SHOPIFY_ADMIN_PASSWORD=
