# ─── Railway webhook (dispatches GitHub Actions) ────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000

# ─── GitHub Actions secrets ─────────────────────────────────────────────────
SHOPIFY_SESSION_COOKIES=
CAPSOLVER_API_KEY=
# Sticky residential proxy (required for Shopify Cloudflare interstitial on Railway)
# Format: host:port:user:pass  — browser + CapSolver must use the same proxy IP
# Providers: IPRoyal, Webshare, Bright Data (sticky/session mode, not rotating)
CAPSOLVER_PROXY=
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─── Local dev (optional) ───────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://your-org.atlassian.net
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2
APP=
CYCLE_ID=
DISPLAY=:99
