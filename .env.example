# ─── Railway webhook ────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000

# ─── BrowserStack Automate (Playwright CDP) + Shopify login ─────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
# Optional: skip login if cookies exported from dev store admin
SHOPIFY_SESSION_COOKIES=
SHOPIFY_ADMIN_EMAIL=
SHOPIFY_ADMIN_PASSWORD=
SHOPIFY_2FA_SECRET=
# CapSolver only (Cloudflare challenge API — not passed to browser)
# CAPSOLVER_API_KEY=
# CAPSOLVER_PROXY=

# ─── Test runner ────────────────────────────────────────────────────────────
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Set true to run only the first test case in a cycle (smoke test)
# SMOKE_TEST=true

# ─── Local dev (optional) ───────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://your-org.atlassian.net
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2
APP=
CYCLE_ID=
