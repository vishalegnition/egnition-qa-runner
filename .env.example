# ─── Railway (webhook + browser test runner) ────────────────────────────────
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=egnition-qa-runner
PORT=3000
# Set to true to dispatch GitHub Actions instead of running browser on Railway
RUN_TESTS_ON_GITHUB=false
# Same cookie JSON as GitHub — required on Railway for browser tests
SHOPIFY_SESSION_COOKIES=
ZEPHYR_API_TOKEN=
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
CAPSOLVER_API_KEY=

# ─── Local dev (optional) ───────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://your-org.atlassian.net
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2
# OPENROUTER_MODEL=   # optional override; auto-selects best Gemini vision model if unset
APP=
CYCLE_ID=
RUN_ON_RAILWAY=1
DISPLAY=:99
